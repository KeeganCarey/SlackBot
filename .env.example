# Slack credentials — from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token   # required for Socket Mode
SLACK_SIGNING_SECRET=your-signing-secret

# Backend — "gemini" (default), "openai", or "lmstudio"
BACKEND=openai

# Gemini (used when BACKEND=gemini)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash  # see app/ai/gemini_agent.py for all options

# OpenAI (used when BACKEND=openai)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5-nano
OPENAI_REASONING_EFFORT=low
# Optional: cap output tokens for faster short replies (0 = no cap)
OPENAI_MAX_COMPLETION_TOKENS=0

# Google Calendar tool (create_calendar_event)
# OAuth client credentials JSON from Google Cloud Console
GOOGLE_CALENDAR_CREDENTIALS_FILE=google_oauth_client_secret.json
# Token cache written after first successful OAuth flow
GOOGLE_CALENDAR_TOKEN_FILE=.secrets/google_calendar_token.json
# Optional defaults used by create_calendar_event when args are omitted
GOOGLE_CALENDAR_DEFAULT_ID=primary
GOOGLE_CALENDAR_DEFAULT_TIMEZONE=America/Los_Angeles
# Use console flow if local browser callback is unavailable
GOOGLE_CALENDAR_USE_CONSOLE_AUTH=false

# LM Studio (used when BACKEND=lmstudio)
LMSTUDIO_URL=http://127.0.0.1:1234
LMSTUDIO_MODEL=gemma4-E4B

# Slack streaming behavior (optional tuning)
SLACK_UPDATE_INTERVAL_SECONDS=0.35
SLACK_MIN_CHARS_PER_UPDATE=8
SLACK_USE_NATIVE_STREAMING=true
SLACK_NATIVE_STREAM_FLUSH_INTERVAL_SECONDS=0.08
SLACK_NATIVE_STREAM_MIN_CHARS=18
SLACK_SHOW_TOOL_DEBUG=true

# Tools manifest bootstrap behavior
# false (default): reuse existing valid manifest even if CSV fingerprint changed
# true: regenerate valid manifest when CSV fingerprint changes
TOOL_MANIFEST_REGENERATE_ON_FINGERPRINT_MISMATCH=false
